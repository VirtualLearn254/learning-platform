{
  "name": "@lp/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "dev:workers": "tsx watch --clear-screen=false src/workers/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push --force",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@hono/zod-validator": "^0.4.0",
    "@lp/ai-provider": "*",
    "@lp/concept-graph": "*",
    "@lp/hermes-bridge": "*",
    "@lp/image-search": "*",
    "@lp/lrs": "*",
    "@lp/notifications": "*",
    "@lp/pdf-generator": "*",
    "@lp/render-engine": "*",
    "@lp/scorm-packager": "*",
    "@lp/shared": "*",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "bullmq": "^5.34.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.6.0",
    "ioredis": "^5.4.0",
    "pdf-parse": "^1.1.1",
    "postgres": "^3.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
