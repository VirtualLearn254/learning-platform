# Production environment variables for the Contabo VPS stack.
# Copy this to .env.prod ON THE VPS and fill in real values.
# Never commit the actual .env.prod.

# ── Secrets (CHANGE THESE) ──────────────────────────────────────────
POSTGRES_PASSWORD=__changeme_strong_password__
MINIO_ROOT_USER=lp_admin
MINIO_ROOT_PASSWORD=__changeme_minio_root_password__

# ── App ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
API_PORT=3001

# ── S3 / object storage ─────────────────────────────────────────────
# These are the credentials the app uses (NOT the MinIO root credentials).
# You'll create a separate IAM-like user inside MinIO after first boot.
S3_REGION=us-east-1
S3_BUCKET=learning-platform
S3_ACCESS_KEY=__app_minio_access_key__
S3_SECRET_KEY=__app_minio_secret_key__
S3_FORCE_PATH_STYLE=true

# ── AI providers — leave blank to use placeholders ──────────────────
# Real values plug in later when GPU stack is online.
VLLM_BASE_URL=
VLLM_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
XTTS_BASE_URL=
VLM_BASE_URL=

# ── Hermes + notifications (configure later) ────────────────────────
HERMES_RPC_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Image search (configure later) ──────────────────────────────────
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=
