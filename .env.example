# Copy to .env at the repo root. Each app reads from process.env via dotenv.
# .env is gitignored; only .env.example is committed.

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgres://lp:lp_dev_password@localhost:5432/learning_platform

# ── Redis (BullMQ) ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Object storage (S3-compatible; MinIO locally, R2 in prod) ────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=learning-platform-dev
S3_ACCESS_KEY=lp_dev
S3_SECRET_KEY=lp_dev_password_minio
S3_FORCE_PATH_STYLE=true

# ── AI providers ─────────────────────────────────────────────────────
# vLLM is the local GPU LLM endpoint (running on the Runpod box).
# When running the API locally for dev, this can point to a tunneled
# Runpod pod or to a local Ollama/llama.cpp for testing.
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=local-key
VLLM_MODEL=Qwen/Qwen2.5-32B-Instruct-AWQ

# Cloud fallbacks (used when local is unavailable or quality demands it)
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# TTS endpoint (Coqui XTTS-v2 served from the GPU box)
XTTS_BASE_URL=http://localhost:8001
XTTS_VOICE_DEFAULT=onyx

# Vision verifier endpoint (Qwen2-VL or LLaVA-Next)
VLM_BASE_URL=http://localhost:8002/v1
VLM_MODEL=Qwen/Qwen2-VL-7B-Instruct

# ── App config ───────────────────────────────────────────────────────
API_PORT=3001
WEB_PORT=3000
WEB_API_BASE_URL=http://localhost:3001
LOG_LEVEL=info

# ── Hermes agent (set when integrating; can be empty during P0/P1) ──
HERMES_RPC_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Image search providers (P3) ──────────────────────────────────────
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=
